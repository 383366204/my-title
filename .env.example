# GLM API 密钥 (从智谱开放平台获取)
GLM_API_KEY=your_glm_api_key_here

# GLM API 地址（可选，默认使用官方地址）
# GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4

# GLM 模型名称（可选，默认 glm-4-flash）
# 推荐: glm-4-flash (免费), glm-4-plus (更快)
# GLM_API_MODEL=glm-4-flash

# 1688 AI 版 Access Key (从 1688 AI 店长 APP 获取)
# 格式: 前 32 字符是 Secret，剩余是 KeyID
ALI_1688_AK=your_1688_access_key_here

# taobao-native CLI (可选依赖，用于淘宝同行标题搜索)
# WSL2 默认路径: /mnt/c/Users/<用户名>/AppData/Local/Programs/taobao/bin/taobao-native.cmd
# TAOBAO_NATIVE_PATH=
# TAOBAO_NATIVE_TIMEOUT=10000

# 1688 API 限流配置
API_RATE_LIMIT_MAX=20
API_RATE_LIMIT_WINDOW=60000
API_429_COOLDOWN=3600000
API_RATE_LIMIT_QUEUE_MAX=10

# 批量选品默认商品数上限（每关键词）
BATCH_DEFAULT_LIMIT=5

# 生意参谋 SYCM 登录态缓存（人工登录一次后复用）
SYCM_LOGIN_MODE=manual
# Windows 示例: C:\Users\YourUsername\AppData\Local\ecom-ai-tools-chrome
# Linux/云服务器示例: /data/ecom-ai-tools/chrome-profile/sycm
# SYCM_CHROME_PROFILE_DIR=/data/ecom-ai-tools/chrome-profile/sycm
# SYCM_REMOTE_DEBUGGING_PORT=9222

# 标题生成超时（毫秒，默认 120000）
# RUN_TIMEOUT=120000

# LLM provider for title generation: glm, deepseek, minimax, openai-compatible
LLM_PROVIDER=minimax

# Generic OpenAI-compatible fallback (used by LLM_PROVIDER=openai-compatible)
# LLM_API_KEY=
# LLM_API_BASE=
# LLM_MODEL=
# LLM_TIMEOUT=30000
# LLM_LONG_TIMEOUT=60000

# DeepSeek OpenAI-compatible chat completions
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash

# MiniMax OpenAI-compatible chat completions
# LLM_PROVIDER=minimax
# MINIMAX_API_KEY=
# MINIMAX_API_BASE=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M2.7
