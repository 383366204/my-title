# GLM API 密钥 (从智谱开放平台获取)
GLM_API_KEY=your_glm_api_key_here

# GLM API 地址（可选，默认使用官方地址）
# GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4

# GLM 模型名称（可选，默认 glm-4-flash 免费模型较慢）
# 推荐: glm-4-flash (免费), glm-4-plus (更快), glm-5.1 (火山引擎方舟)
# GLM_API_MODEL=glm-4-flash

# 1688 AI 版 Access Key (从 1688 AI 店长 APP 获取)
# 格式: 前 32 字符是 Secret，剩余是 KeyID
ALI_1688_AK=your_1688_access_key_here

# taobao-native CLI (可选依赖，用于替代手动输入)
# 如未安装，程序将使用 --peer-titles 模式手动输入同行标题
# WSL2 默认路径: /mnt/c/Users/<用户名>/AppData/Local/Programs/taobao/bin/taobao-native.cmd
# TAOBAO_NATIVE_PATH=
# TAOBAO_NATIVE_TIMEOUT=10000

# 1688 API 限流配置（防止 429 限流导致整天无法使用）
# 每个时间窗口内最大 API 请求数
API_RATE_LIMIT_MAX=20
# 时间窗口大小（毫秒，默认 60 秒）
API_RATE_LIMIT_WINDOW=60000
# 触发 429 后冷却时间（毫秒，默认 1 小时）
API_429_COOLDOWN=3600000
# 限流排队最大数量（超出则直接拒绝）
API_RATE_LIMIT_QUEUE_MAX=10

# 批量选品默认商品数上限（每关键词，避免 GLM 生成过慢）
BATCH_DEFAULT_LIMIT=5

# 聊天机器人平台配置（可选）
# BOT_PLATFORMS=feishu,dingtalk,wechat

# 飞书机器人: https://open.feishu.cn/document/server-docs/getting-started/getting-an-app
# FEISHU_APP_ID=your-app-id
# FEISHU_APP_SECRET=your-app-secret

# 钉钉机器人: https://developers.dingtalk.com/document/app/custom-robot-access
# DINGTALK_CLIENT_ID=your-client-id
# DINGTALK_CLIENT_SECRET=your-client-secret

# 微信 iLink 机器人: 启动时扫码登录，无需预配置 token
# 凭证自动保存到项目根目录 .wx-credentials.json
# 微信 Bot 凭证路径（多账号用逗号分隔）
# WECHAT_CREDENTIALS_PATHS=.wx-bot1.json,.wx-bot2.json
# 单账号也可使用旧变量（向后兼容）:
# WECHAT_CREDENTIALS_PATH=.wx-credentials.json

# 火山引擎方舟 API（可选，优先于智谱 GLM）
# 从 https://console.volcengine.com/ark 获取 Coding Plan Key
# VOLC_API_KEY=your_volc_api_key_here
# VOLC_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3

# --- Advanced/Optional ---
# Workflow timeout in milliseconds (default: 120000 = 2 minutes)
# RUN_TIMEOUT=120000

# Enable delay between 1688 API requests for rate limiting (set to 'true' to enable)
# ENABLE_DELAY=false
